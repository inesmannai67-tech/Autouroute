<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for local/dev servers - required for XAMPP -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
